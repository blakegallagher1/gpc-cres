{
  "name": "entitlement-os",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/node": "^22.13.4",
    "@types/pg": "^8.11.6",
    "dotenv": "^16.4.5",
    "eslint": "^9.20.1",
    "pg": "^8.19.0",
    "prisma": "6.19.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.0",
    "vitest": "^4.0.18"
  },
  "scripts": {
    "dev": "pnpm -r --filter './packages/**' build && pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r --filter './packages/**' build && pnpm -r typecheck",
    "test": "pnpm -r test && pnpm exec vitest run tests/episode.test.ts tests/retrieval.test.ts tests/reflection.test.ts tests/reward.test.ts tests/smoke_endpoints.test.ts",
    "test:docs": "node scripts/testing/validate-docs.mjs",
    "test:web:observability": "pnpm -C apps/web run test:observability",
    "test:matrix:generate": "node scripts/testing/generate-test-matrix.mjs",
    "test:matrix:validate": "node scripts/testing/validate-test-matrix.mjs",
    "test:phase1:stubs:generate": "node scripts/testing/generate-phase1-stubs.mjs",
    "test:phase1:track": "node scripts/testing/track-phase1-coverage.mjs",
    "test:phase1:track:complete": "node scripts/testing/track-phase1-coverage.mjs --require-complete",
    "parcel:check:propertydb": "pnpm exec tsx scripts/parcels/check_property_db_runtime.ts",
    "parcel:backfill:dry": "pnpm exec tsx scripts/parcels/backfill_property_db_from_csv.ts",
    "parcel:backfill:apply": "pnpm exec tsx scripts/parcels/backfill_property_db_from_csv.ts --apply",
    "parcel:address-backfill:dry": "pnpm exec tsx scripts/parcels/backfill_org_parcel_addresses.ts",
    "parcel:address-backfill:apply": "pnpm exec tsx scripts/parcels/backfill_org_parcel_addresses.ts --apply",
    "parcel:smoke:prod": "pnpm exec tsx scripts/parcels/smoke_map_parcel_prod.ts",
    "ebr:load": "pnpm exec tsx scripts/parcels/load_ebr_parcels.ts",
    "copy-gpc-moat-tables": "pnpm exec tsx scripts/copy-gpc-moat-tables.ts",
    "smoke:endpoints": "pnpm exec tsx scripts/smoke_endpoints.ts",
    "smoke:gateway:edge-access": "pnpm exec tsx scripts/smoke_gateway_edge_access.ts",
    "observability:monitor:prod": "pnpm exec tsx scripts/observability/monitor_production.ts",
    "db:migrate": "pnpm run db:migrate:local",
    "db:migrate:local": "pnpm -C packages/db run migrate:deploy:local",
    "db:migrate:remote": "pnpm -C packages/db run migrate:dev",
    "db:deploy": "pnpm -C packages/db run migrate:deploy",
    "db:seed": "pnpm -C packages/db run seed",
    "migrate:evidence:b2": "pnpm exec tsx packages/evidence/src/scripts/migrate-supabase-to-b2.ts",
    "migrate:evidence:b2:dry": "pnpm exec tsx packages/evidence/src/scripts/migrate-supabase-to-b2.ts --dry-run"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "ws": "^8.19.0"
  },
  "pnpm": {
    "overrides": {
      "rollup@>=4.0.0 <4.59.0": "4.59.0",
      "minimatch@<4": "3.1.4",
      "minimatch@>=9 <9.0.7": "9.0.9",
      "ajv@>=6 <6.14.0": "6.14.0",
      "ajv@>=8 <8.18.0": "8.18.0",
      "markdown-it@>=14 <14.1.1": "14.1.1",
      "hono@<4.11.10": "4.11.10",
      "qs@>=6.7.0 <6.14.2": "6.14.2"
    }
  }
}

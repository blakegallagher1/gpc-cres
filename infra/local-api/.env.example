# =============================================================================
# Local API Server Environment Variables
# =============================================================================
# Copy to .env and fill in values. Postgres (5432) is never exposed to the internet.

# Application Database (deals, orgs, jurisdictions - entitlement_os)
# Required for GET /deals
APPLICATION_DATABASE_URL=postgresql://postgres:your-password-here@localhost:5432/entitlement_os

# Property Database (parcels, screening, tiles - same entitlement_os DB)
# Required for /tiles proxy and /api/parcels/* endpoints
DATABASE_URL=postgresql://postgres:your-password-here@localhost:5432/entitlement_os

# Martin Tile Server
MARTIN_URL=http://localhost:3000

# API Authentication (comma-separated keys)
# Generate: openssl rand -hex 32
API_KEYS=key1,key2

# CORS Origins (comma-separated; default deny if unset)
ALLOWED_ORIGINS=https://gallagherpropco.com,https://www.gallagherpropco.com,http://localhost:3000

# API Authentication (GATEWAY_API_KEY used by Vercel as LOCAL_API_KEY)
GATEWAY_API_KEY=your-secret-api-key

# Admin API Authentication (separate from GATEWAY_API_KEY)
# Required for /admin/* endpoints (deploy, containers, DB queries)
# Generate: openssl rand -hex 32
ADMIN_API_KEY=your-admin-api-key

# B2 Storage (evidence, artifacts, uploads)
# Required for /storage/upload-bytes and /storage/download-url
B2_S3_ENDPOINT_URL=https://s3.us-west-004.backblazeb2.com
B2_ACCESS_KEY_ID=your-application-key-id
B2_SECRET_ACCESS_KEY=your-application-key
B2_BUCKET=your-bucket-name
B2_REGION=us-west-004

# Server
PORT=8000
HOST=0.0.0.0

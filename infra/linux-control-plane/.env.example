# Linux control-plane env
# This host becomes the public runtime for gateway + CUA.
# Property data and knowledge-base dependencies remain on the Windows PC.

WINDOWS_HOST_TAILSCALE_IP=100.67.140.126

# Windows-backed dependencies reached from Linux over Tailscale.
WINDOWS_PROPERTY_DB_URL=postgresql://postgres:postgres@100.67.140.126:5432/entitlement_os
WINDOWS_APP_DB_URL=postgresql://postgres:postgres@100.67.140.126:54323/entitlement_os
WINDOWS_MARTIN_URL=http://100.67.140.126:3000
WINDOWS_QDRANT_URL=http://100.67.140.126:6333

# Public gateway auth
API_KEYS=
ADMIN_API_KEY=
ALLOWED_ORIGINS=https://gallagherpropco.com,https://www.gallagherpropco.com

# Storage / shared runtime env
B2_S3_ENDPOINT_URL=
B2_ACCESS_KEY_ID=
B2_SECRET_ACCESS_KEY=
B2_BUCKET=
B2_REGION=us-west-004

# CUA runtime
OPENAI_API_KEY=
CUA_BROWSER_MODE=headless
CUA_DEFAULT_MODEL=gpt-5.4-mini
CUA_MAX_TURNS=24
GPC_PROD_SITE_ALLOWED_HOSTS=gallagherpropco.com,www.gallagherpropco.com
GPC_PROD_SITE_LOGIN_PATH=/login
GPC_PROD_SITE_EMAIL=
GPC_PROD_SITE_PASSWORD=
GPC_PROD_SITE_BOOTSTRAP_TIMEOUT_MS=30000

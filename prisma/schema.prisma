/**
 * Prisma schema for Data Agent 2.0 memory, retrieval, and reinforcement models.
 * This schema is intentionally lean and scoped to episodic memory + knowledge graph
 * primitives while preserving extensibility for additional domain tables.
 */

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model Episode {
  id            String   @id @default(uuid()) @db.Uuid
  runId         String   @map("run_id") @unique(map: "Episode_run_id_key")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  agentIntent   String   @map("agent_intent") @db.Text
  evidenceHash  String   @map("evidence_hash") @db.Text
  retrievalMeta Json     @map("retrieval_meta") @db.JsonB
  modelOutputs  Json     @map("model_outputs") @db.JsonB
  confidence    Float?
  outcomeSignal String?  @map("outcome_signal") @db.Text
  nextStateHash String?  @map("next_state_hash") @db.Text
  summary       String?  @db.Text

  @@map("Episode")
  @@index([agentIntent], map: "idx_episode_agent_intent")
  @@index([runId], map: "idx_episode_run_id")
}

model KGEvent {
  id         String   @id @default(uuid()) @db.Uuid
  subjectId  String   @map("subject_id") @db.Text
  predicate  String   @db.Text
  objectId   String   @map("object_id") @db.Text
  timestamp  DateTime @default(now()) @db.Timestamptz(6)
  confidence Float
  sourceHash String   @map("source_hash") @db.Text

  @@map("KGEvent")
  @@index([subjectId], map: "idx_kgevent_subject_id")
  @@index([objectId], map: "idx_kgevent_object_id")
}

model TemporalEdge {
  id        String @id @default(uuid()) @db.Uuid
  fromEvent String @map("from_event") @db.Uuid
  toEvent   String @map("to_event") @db.Uuid
  relation  String @db.Text

  @@map("TemporalEdge")
  @@index([fromEvent], map: "idx_temporal_from")
  @@index([toEvent], map: "idx_temporal_to")
}

model RewardSignal {
  id        String   @id @default(uuid()) @db.Uuid
  episodeId String   @map("episode_id") @db.Uuid
  userScore Int      @map("user_score")
  autoScore Float    @map("auto_score")
  timestamp DateTime @default(now()) @map("timestamp") @db.Timestamptz(6)

  @@map("RewardSignal")
  @@index([episodeId], map: "idx_reward_episode")
}

model KnowledgeEmbedding {
  id             String                   @id @default(uuid()) @db.Uuid
  contentType    String                   @map("content_type") @db.Text
  sourceId       String                   @map("source_id") @db.Text
  contentText    String                   @map("content_text") @db.Text
  embedding      Unsupported("vector(1536)")?
  vectorEmbedding Unsupported("vector(1536)")? @map("vector_embedding")
  metadata       Json                     @default("{}") @db.JsonB
  createdAt      DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("KnowledgeEmbedding")
  @@index([contentType], map: "idx_knowledge_content_type")
  @@index([sourceId], map: "idx_knowledge_source_id")
}

// ---------------------------------------------------------------------------
// Cartographer models — spatial intelligence persistence
// All rows scoped with orgId for multi-tenancy.
// ---------------------------------------------------------------------------

model SavedThesis {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @map("org_id") @db.Text
  name        String   @db.Text
  description String?  @db.Text
  weights     Json     @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy   String?  @map("created_by") @db.Text

  @@map("saved_thesis")
  @@index([orgId], map: "idx_saved_thesis_org_id")
  @@index([orgId, name], map: "idx_saved_thesis_org_name")
}

model SavedLayer {
  id               String   @id @default(uuid()) @db.Uuid
  orgId            String   @map("org_id") @db.Text
  name             String   @db.Text
  description      String?  @db.Text
  layerType        String   @map("layer_type") @db.Text
  sqlQuery         String?  @map("sql_query") @db.Text
  geojsonSnapshot  Json?    @map("geojson_snapshot") @db.JsonB
  style            Json?    @db.JsonB
  metadata         Json     @default("{}") @db.JsonB
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy        String?  @map("created_by") @db.Text

  @@map("saved_layer")
  @@index([orgId], map: "idx_saved_layer_org_id")
  @@index([orgId, layerType], map: "idx_saved_layer_org_type")
}

model SiteFitScore {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @map("org_id") @db.Text
  thesisId    String?  @map("thesis_id") @db.Uuid
  thesisName  String   @map("thesis_name") @db.Text
  parcelId    String   @map("parcel_id") @db.Text
  score       Float
  breakdown   Json     @db.JsonB
  computedAt  DateTime @map("computed_at") @db.Timestamptz(6)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("site_fit_score")
  @@index([orgId], map: "idx_site_fit_score_org_id")
  @@index([orgId, thesisId], map: "idx_site_fit_score_org_thesis")
  @@index([orgId, parcelId], map: "idx_site_fit_score_org_parcel")
}

model AssemblageCandidate {
  id                String   @id @default(uuid()) @db.Uuid
  orgId             String   @map("org_id") @db.Text
  assemblageName    String   @map("assemblage_name") @db.Text
  parcelIds         Json     @map("parcel_ids") @db.JsonB
  totalAcreage      Float    @map("total_acreage")
  combinedGeometry  Json?    @map("combined_geometry") @db.JsonB
  fitScore          Float?   @map("fit_score")
  notes             String?  @db.Text
  metadata          Json     @default("{}") @db.JsonB
  computedAt        DateTime @map("computed_at") @db.Timestamptz(6)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("assemblage_candidate")
  @@index([orgId], map: "idx_assemblage_candidate_org_id")
  @@index([orgId, fitScore], map: "idx_assemblage_candidate_org_score")
}

model HypotheticalSitePlan {
  id           String   @id @default(uuid()) @db.Uuid
  orgId        String   @map("org_id") @db.Text
  planName     String   @map("plan_name") @db.Text
  parcelIds    Json     @map("parcel_ids") @db.JsonB
  zones        Json     @db.JsonB
  totalAcreage Float    @map("total_acreage")
  notes        String?  @db.Text
  metadata     Json     @default("{}") @db.JsonB
  computedAt   DateTime @map("computed_at") @db.Timestamptz(6)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy    String?  @map("created_by") @db.Text

  @@map("hypothetical_site_plan")
  @@index([orgId], map: "idx_hypothetical_site_plan_org_id")
}

model MapCuriosityTrail {
  id              String   @id @default(uuid()) @db.Uuid
  orgId           String   @map("org_id") @db.Text
  label           String   @db.Text
  description     String   @db.Text
  trigger         String   @db.Text
  suggestedActions Json    @map("suggested_actions") @db.JsonB
  relevanceScore  Float    @map("relevance_score")
  viewportBbox    Json?    @map("viewport_bbox") @db.JsonB
  accepted        Boolean  @default(false)
  dismissed       Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy       String?  @map("created_by") @db.Text

  @@map("map_curiosity_trail")
  @@index([orgId], map: "idx_map_curiosity_trail_org_id")
  @@index([orgId, accepted], map: "idx_map_curiosity_trail_org_accepted")
}

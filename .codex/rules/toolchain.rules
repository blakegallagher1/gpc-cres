# Entitlement OS toolchain rules
# Allows common monorepo commands without approval prompts

# pnpm workspace commands
prefix_rule(pattern=["pnpm", "install"], decision="allow")
prefix_rule(pattern=["pnpm", "dev"], decision="allow")
prefix_rule(pattern=["pnpm", "build"], decision="allow")
prefix_rule(pattern=["pnpm", "lint"], decision="allow")
prefix_rule(pattern=["pnpm", "typecheck"], decision="allow")
prefix_rule(pattern=["pnpm", "test"], decision="allow")
prefix_rule(pattern=["pnpm", "db:migrate"], decision="allow")
prefix_rule(pattern=["pnpm", "db:deploy"], decision="allow")
prefix_rule(pattern=["pnpm", "db:seed"], decision="allow")
prefix_rule(pattern=["pnpm", "db:generate"], decision="allow")
prefix_rule(pattern=["pnpm", "db:push"], decision="allow")
prefix_rule(pattern=["pnpm", "db:studio"], decision="allow")
prefix_rule(pattern=["pnpm", "add"], decision="allow")
prefix_rule(pattern=["pnpm", "remove"], decision="allow")
prefix_rule(pattern=["pnpm", "run"], decision="allow")
prefix_rule(pattern=["pnpm", "exec"], decision="allow")
prefix_rule(pattern=["pnpm", "--filter"], decision="allow")

# Prisma CLI (direct invocation)
prefix_rule(pattern=["npx", "prisma"], decision="allow")
prefix_rule(pattern=["pnpm", "dlx", "prisma"], decision="allow")

# GitHub CLI (full autonomy per AGENTS.md)
prefix_rule(pattern=["gh", "pr"], decision="allow")
prefix_rule(pattern=["gh", "issue"], decision="allow")
prefix_rule(pattern=["gh", "run"], decision="allow")
prefix_rule(pattern=["gh", "release"], decision="allow")
prefix_rule(pattern=["gh", "api"], decision="allow")
prefix_rule(pattern=["gh", "auth"], decision="allow")
prefix_rule(pattern=["gh", "repo"], decision="allow")

# Git operations (safe subset)
prefix_rule(pattern=["git", "status"], decision="allow")
prefix_rule(pattern=["git", "diff"], decision="allow")
prefix_rule(pattern=["git", "log"], decision="allow")
prefix_rule(pattern=["git", "branch"], decision="allow")
prefix_rule(pattern=["git", "add"], decision="allow")
prefix_rule(pattern=["git", "commit"], decision="allow")
prefix_rule(pattern=["git", "push"], decision="allow")
prefix_rule(pattern=["git", "pull"], decision="allow")
prefix_rule(pattern=["git", "fetch"], decision="allow")
prefix_rule(pattern=["git", "checkout"], decision="allow")
prefix_rule(pattern=["git", "switch"], decision="allow")
prefix_rule(pattern=["git", "rebase"], decision="allow")
prefix_rule(pattern=["git", "stash"], decision="allow")
prefix_rule(pattern=["git", "show"], decision="allow")

# Vercel CLI
prefix_rule(pattern=["vercel"], decision="allow")
prefix_rule(pattern=["npx", "vercel"], decision="allow")

# Docker (local infra)
prefix_rule(pattern=["docker", "compose"], decision="allow")
prefix_rule(pattern=["docker", "ps"], decision="allow")
prefix_rule(pattern=["docker", "logs"], decision="allow")

# Node/TypeScript tools
prefix_rule(pattern=["node"], decision="allow")
prefix_rule(pattern=["npx", "tsx"], decision="allow")
prefix_rule(pattern=["npx", "tsc"], decision="allow")

# Process management (for dev servers)
prefix_rule(pattern=["lsof", "-i"], decision="allow")

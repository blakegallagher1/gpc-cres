# Entitlement OS v1.0 - Local/Dev Environment Variables
#
# Copy to `.env` and fill in values. Do not commit `.env`.
#
# PC backend + Cloudflare (canonical names, URLs, env var list): docs/server-manifest.json
# Operator runbooks: docs/SERVER_MANAGEMENT.md, docs/CLOUDFLARE.md, docs/claude/backend.md

# Postgres (Supabase or local dev)
# - DATABASE_URL: MUST use port 6543 (Supavisor Transaction Mode) for serverless.
#   Port 5432 (Session Mode) exhausts connections under parallel LLM tool calls.
# - DIRECT_DATABASE_URL: direct connection for Prisma migrations (port 5432 OK)
# - READ_REPLICA_DATABASE_URL: optional pooled read replica for read-heavy endpoints
DATABASE_URL="postgresql://postgres:your-password-here@localhost:54321/entitlement_os?schema=public"
DIRECT_DATABASE_URL="postgresql://postgres:your-password-here@localhost:54321/entitlement_os?schema=public"
READ_REPLICA_DATABASE_URL=""
ENABLE_READ_REPLICA="false"
# Optional Prisma pool tuning (query string params are appended when missing)
PRISMA_CONNECTION_LIMIT="15"
PRISMA_POOL_TIMEOUT_SECONDS="20"

# Auth is handled by NextAuth with local DB credentials (see apps/web/.env.example).
# Supabase has been fully removed from the codebase.

# Screening / Copilot / Deal-room backend (public web origin required at runtime)
# Production/preview requires this to point to your deployed FastAPI/backend host.
NEXT_PUBLIC_BACKEND_URL="https://YOUR_SCREENING_BACKEND_URL"

# Map / Martin Tile Server (Phase 2 — optional)
# When set, parcel vector tiles load directly from HP Martin; otherwise via /api/map/tiles proxy.
# Example: http://192.168.1.164:3000 (Martin RPC: get_parcel_mvt)
# NEXT_PUBLIC_TILE_SERVER_URL=""
# Optional zoning tile overrides. By default the web app uses the authenticated
# `/api/map/zoning-tiles` proxy, which fetches `get_parcel_mvt` server-side.
# Only set these when you want the browser to target a specific Martin source
# directly.
# NEXT_PUBLIC_ZONING_TILE_SOURCE_ID="get_zoning_mvt"
# NEXT_PUBLIC_ZONING_TILE_SOURCE_LAYER="zoning"
# NEXT_PUBLIC_ZONING_TILE_PROPERTY_NAME="zoning_type"

# Local API (FastAPI via Cloudflare Tunnel) — production
# Deals list and other backend data; server-side only. Never expose to client.
LOCAL_API_URL="https://api.gallagherpropco.com"
LOCAL_API_KEY=""
CF_ACCESS_CLIENT_ID="your-cf-access-client-id-here"
CF_ACCESS_CLIENT_SECRET="your-cf-access-client-secret-here"
# Required for evidence uploads (parish-pack, change-detection, source-ingestion, worker).
# Use a valid user UUID from your org.
GATEWAY_SERVICE_USER_ID=""

# OpenAI
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"
OPENAI_PARISH_PACK_MODEL="gpt-5.2"
OPENAI_TRIAGE_MODEL="gpt-5.2"
OPENAI_ARTIFACT_MODEL="gpt-5.2"

# Perplexity Agent API (web research tools)
PERPLEXITY_API_KEY=""

# Socrata building permits feed (optional app token raises rate limits)
SOCRATA_BASE_URL="https://data.brla.gov/resource"
SOCRATA_EBR_PERMITS_DATASET_ID="7fq7-8j7r"
SOCRATA_APP_TOKEN=""

# Google Maps
GOOGLE_MAPS_API_KEY=""
# Google Maps Grounding Lite MCP (gives agents access to search_places, compute_routes, lookup_weather)
GOOGLE_MAPS_GROUNDING_LITE_ENABLED=false

# OpenAI marketplace plugin adapters (server-side only)
GITHUB_PLUGIN_TOKEN=""
VERCEL_PLUGIN_TOKEN=""
CLOUDFLARE_PLUGIN_TOKEN=""
NEPTUNE_FLOOD_API_KEY=""
# Neptune-issued API Express base URL for live quote/risk requests
NEPTUNE_FLOOD_BASE_URL=""

# Temporal (optional — zero-cost migration path does not use it)
# Set ENABLE_TEMPORAL=true to run the worker; otherwise pnpm dev skips it
ENABLE_TEMPORAL=
TEMPORAL_ADDRESS="localhost:7233"
TEMPORAL_NAMESPACE="default"
TEMPORAL_TASK_QUEUE="entitlement-os"

# Phase 1: Local app DB (optional — after migrating from Supabase)
# APP_DB_PASSWORD=""
# DATABASE_URL="postgresql://postgres:APP_DB_PASSWORD@localhost:5433/entitlement_os"
# DIRECT_DATABASE_URL="postgresql://postgres:APP_DB_PASSWORD@localhost:5433/entitlement_os"


# Optional: enable more verbose logs in worker
LOG_LEVEL="info"

# Chat session memory/runtime tuning (optional)
AGENT_SESSION_COMPACTION_TOKEN_THRESHOLD="6000"
AGENT_SESSION_COMPACTION_KEEP_RECENT_MESSAGES="24"
AGENT_SESSION_DEDUPE_LOOKBACK="200"

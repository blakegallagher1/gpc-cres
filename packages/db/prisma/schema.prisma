generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum sku_type {
  SMALL_BAY_FLEX
  OUTDOOR_STORAGE
  TRUCK_PARKING
}

enum deal_status {
  INTAKE
  TRIAGE_DONE
  PREAPP
  CONCEPT
  NEIGHBORS
  SUBMITTED
  HEARING
  APPROVED
  EXIT_MARKETED
  EXITED
  KILLED
}

enum deal_asset_class {
  LAND
  INDUSTRIAL
  OFFICE
  RETAIL
  MULTIFAMILY
  SELF_STORAGE
  HOSPITALITY
  MIXED_USE
  SPECIALTY
  PORTFOLIO
}

enum deal_strategy {
  ENTITLEMENT
  GROUND_UP_DEVELOPMENT
  VALUE_ADD_ACQUISITION
  CORE_ACQUISITION
  LEASE_UP
  ASSET_MANAGEMENT
  RECAPITALIZATION
  REFINANCE
  DISPOSITION
  DEBT_PLACEMENT
}

enum workflow_template_key {
  ENTITLEMENT_LAND
  DEVELOPMENT
  ACQUISITION
  LEASE_UP
  ASSET_MANAGEMENT
  DISPOSITION
  REFINANCE
  PORTFOLIO_REVIEW
}

enum deal_stage_key {
  ORIGINATION
  SCREENING
  UNDERWRITING
  DUE_DILIGENCE
  CONTRACTING
  EXECUTION
  ASSET_MANAGEMENT
  DISPOSITION
  CLOSED_WON
  CLOSED_LOST
}

enum opportunity_kind {
  SITE
  PROPERTY
  LOAN
  PORTFOLIO
  TENANT
  JV
}

enum deal_source_type {
  MANUAL
  BROKER
  OWNER_DIRECT
  MARKET_SCAN
  AGENT_DISCOVERY
  REFERRAL
  IMPORT
}

enum deal_asset_role {
  PRIMARY
  COMPARABLE
  ADJACENT
}

enum task_status {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELED
}

enum artifact_type {
  TRIAGE_PDF
  SUBMISSION_CHECKLIST_PDF
  HEARING_DECK_PPTX
  EXIT_PACKAGE_PDF
  BUYER_TEASER_PDF
  INVESTMENT_MEMO_PDF
  OFFERING_MEMO_PDF
  COMP_ANALYSIS_PDF
  IC_DECK_PPTX
}

enum evidence_type {
  WEB_PAGE
  PDF
  IMAGE
  TEXT_EXTRACT
}

enum run_type {
  TRIAGE
  PARISH_PACK_REFRESH
  ARTIFACT_GEN
  BUYER_LIST_BUILD
  CHANGE_DETECT
  SOURCE_INGEST
  ENRICHMENT
  INTAKE_PARSE
  DOCUMENT_CLASSIFY
  BUYER_OUTREACH_DRAFT
  ADVANCEMENT_CHECK
  OPPORTUNITY_SCAN
  DEADLINE_MONITOR
}

enum alert_frequency {
  REALTIME
  DAILY
  WEEKLY
}

enum entity_type {
  LLC
  TRUST
  CORP
  INDIVIDUAL

  @@map("entity_type")
}

enum notification_type {
  ALERT
  OPPORTUNITY
  DEADLINE
  SYSTEM
  MARKET
  AUTOMATION
}

enum notification_priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum preference_category {
  DEAL_CRITERIA
  FINANCIAL
  COMMUNICATION
  WORKFLOW
  RISK_TOLERANCE
  TIMING
}

enum preference_value_type {
  NUMBER
  STRING
  ARRAY
  BOOLEAN
  RANGE
  OBJECT
}

enum preference_source {
  CONVERSATION
  DEAL_ACTION
  EXPLICIT_SETTING
  INFERRED
}

enum proactive_trigger_type {
  SCHEDULED
  EVENT
  WEBHOOK
  ANOMALY
}

enum proactive_action_type {
  NOTIFY
  RUN_WORKFLOW
  CREATE_TASK
  AUTO_TRIAGE
}

enum proactive_action_status {
  PENDING
  APPROVED
  REJECTED
  MODIFY_REQUESTED
  AUTO_EXECUTED
  EXPIRED
  FAILED
}

enum proactive_priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum tool_execution_status {
  SUCCESS
  FALLBACK
  INFERRED
  FAILED
}

enum deal_stakeholder_role {
  SPONSOR
  EQUITY_PARTNER
  LENDER
  BROKER
  LAWYER
  TITLE_COMPANY
  CONTRACTOR
  OTHER
}

enum episodic_outcome {
  SUCCESS
  FAILURE
  PARTIAL
}

enum risk_level {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum domain_source_type {
  ZONING_CODE
  MARKET_REPORT
  INTERNAL_MEMO
  SCHEMA_DOC
}

model Org {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  memberships                    OrgMembership[]
  jurisdictions                  Jurisdiction[]
  deals                          Deal[]
  parcels                        Parcel[]
  tasks                          Task[]
  buyers                         Buyer[]
  outreach                       Outreach[]
  runs                           Run[]
  evidenceSources                EvidenceSource[]
  evidenceSnapshots              EvidenceSnapshot[]
  parishPackVersions             ParishPackVersion[]
  artifacts                      Artifact[]
  uploads                        Upload[]
  documentExtractions            DocumentExtraction[]
  conversations                  Conversation[]
  entities                       Entity[]
  taxEvents                      TaxEvent[]
  notifications                  Notification[]
  userPreferences                UserPreference[]
  proactiveTriggers              ProactiveTrigger[]
  proactiveActions               ProactiveAction[]
  toolExecutionMetrics           ToolExecutionMetric[]
  savedSearches                  SavedSearch[]
  entitlementGraphNodes          EntitlementGraphNode[]
  entitlementGraphEdges          EntitlementGraphEdge[]
  entitlementOutcomePrecedents   EntitlementOutcomePrecedent[]
  entitlementPredictionSnapshots EntitlementPredictionSnapshot[]
  dealTerms                      DealTerms[]
  environmentalAssessments       EnvironmentalAssessment[]
  tenants                        Tenant[]
  tenantLeases                   TenantLease[]
  developmentBudgets             DevelopmentBudget[]
  capitalSources                 CapitalSource[]
  capitalDeployments             CapitalDeployment[]
  equityWaterfalls               EquityWaterfall[]
  financings                     DealFinancing[]
  risks                          DealRisk[]
  mapWorkspaces                  MapWorkspace[]
  entitlementPaths               EntitlementPath[]
  stakeholders                   DealStakeholder[]
  propertyTitles                 PropertyTitle[]
  propertySurveys                PropertySurvey[]
  episodicEntries                EpisodicEntry[]
  semanticFacts                  SemanticFact[]
  proceduralSkills               ProceduralSkill[]
  proceduralSkillEpisodes        ProceduralSkillEpisode[]
  domainDocs                     DomainDoc[]
  trajectoryLogs                 TrajectoryLog[]
  toolSpecs                      ToolSpec[]
  evalResults                    EvalResult[]
  internalEntities               InternalEntity[]
  memoryEventLogs                MemoryEventLog[]
  memorySourceRegistries         MemorySourceRegistry[]
  memoryFeedback                 MemoryFeedback[]
  causalImpactTraces             CausalImpactTrace[]
  innovationQueue                InnovationQueue[]
  counterfactualDealLogs         CounterfactualDealLog[]
  entityCollisionAlerts          EntityCollisionAlert[]
  driftFreezeStates              DriftFreezeState[]
  assets                         Asset[]
  dealAssets                     DealAsset[]
  workflowTemplates              WorkflowTemplate[]
  workflowStages                 WorkflowStage[]
  dealStageHistories             DealStageHistory[]
  generalizedScorecards          GeneralizedScorecard[]
  moduleStates                   ModuleState[]
  dealComments                   DealComment[]
  dealContingencies              DealContingency[]
  portfolioAlerts                PortfolioAlert[]
  investmentCriteria             OrgInvestmentCriteria?
  workflowExecutions             WorkflowExecution[]
  areaSummaryCaches              AreaSummaryCache[]
  poiDensityCaches               POIDensityCache[]
  inboundEmails                  InboundEmail[]
  assetPerformancePeriods        AssetPerformancePeriod[]
  capExItems                     CapExItem[]
  tenantChangeEvents             TenantChangeEvent[]
  propertyObservations           PropertyObservation[]
  propertyProfiles               PropertyProfile[]
  propertyLearningCandidates     PropertyLearningCandidate[]
  propertyLearningEvals          PropertyLearningEval[]

  @@map("orgs")
}

model User {
  id           String   @id @db.Uuid
  email        String   @db.Text
  passwordHash String?  @map("password_hash") @db.Text
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  memberships              OrgMembership[]
  dealsCreated             Deal[]                   @relation("deal_created_by")
  tasksOwned               Task[]                   @relation("task_owner_user_id")
  uploadsCreated           Upload[]                 @relation("upload_uploaded_by")
  extractionsReviewed      DocumentExtraction[]     @relation("extraction_reviewed_by")
  conversations            Conversation[]
  notifications            Notification[]
  notificationPreferences  NotificationPreference[]
  preferences              UserPreference[]
  proactiveTriggersCreated ProactiveTrigger[]       @relation("proactive_trigger_created_by")
  proactiveActionsAssigned ProactiveAction[]        @relation("proactive_action_user")
  toolExecutionMetrics     ToolExecutionMetric[]    @relation("tool_execution_metric_user")
  savedSearches            SavedSearch[]
  dealCommentsAuthored     DealComment[]            @relation("deal_comment_author")
  dealContingenciesOwned   DealContingency[]        @relation("deal_contingency_owner")
  assetPerformanceCaptured AssetPerformancePeriod[] @relation("asset_performance_captured_by")

  @@map("users")
}

model OrgMembership {
  orgId     String   @map("org_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      String   @db.Text // owner|admin|member
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  org  Org  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([orgId, userId])
  @@index([userId])
  @@map("org_memberships")
}

model Jurisdiction {
  id              String   @id @default(uuid()) @db.Uuid
  orgId           String   @map("org_id") @db.Uuid
  name            String   @db.Text
  kind            String   @db.Text // parish|city
  state           String   @db.Text
  timezone        String   @db.Text
  officialDomains String[] @map("official_domains")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  org                            Org                             @relation(fields: [orgId], references: [id], onDelete: Cascade)
  seedSources                    JurisdictionSeedSource[]
  deals                          Deal[]
  parishPackVersions             ParishPackVersion[]
  runs                           Run[]
  entitlementGraphNodes          EntitlementGraphNode[]
  entitlementGraphEdges          EntitlementGraphEdge[]
  entitlementOutcomePrecedents   EntitlementOutcomePrecedent[]
  entitlementPredictionSnapshots EntitlementPredictionSnapshot[]

  @@index([orgId])
  @@map("jurisdictions")
}

model JurisdictionSeedSource {
  id             String   @id @default(uuid()) @db.Uuid
  jurisdictionId String   @map("jurisdiction_id") @db.Uuid
  purpose        String   @db.Text // forms|fees|schedule|ordinance|applications
  url            String   @db.Text
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  jurisdiction Jurisdiction @relation(fields: [jurisdictionId], references: [id], onDelete: Cascade)

  @@index([jurisdictionId])
  @@map("jurisdiction_seed_sources")
}

model Deal {
  id                        String                 @id @default(uuid()) @db.Uuid
  orgId                     String                 @map("org_id") @db.Uuid
  name                      String                 @db.Text
  /// @deprecated Compatibility-only field derived from assetClass/strategy/workflowTemplateKey.
  sku                       sku_type
  jurisdictionId            String                 @map("jurisdiction_id") @db.Uuid
  /// @deprecated Compatibility-only field derived from currentStageKey for legacy entitlement clients.
  status                    deal_status            @default(INTAKE)
  assetClass                deal_asset_class?      @map("asset_class")
  assetSubtype              String?                @map("asset_subtype") @db.Text
  strategy                  deal_strategy?
  workflowTemplateKey       workflow_template_key? @map("workflow_template_key")
  currentStageKey           deal_stage_key?        @map("current_stage_key")
  opportunityKind           opportunity_kind?      @map("opportunity_kind")
  dealSourceType            deal_source_type?      @map("deal_source_type")
  primaryAssetId            String?                @map("primary_asset_id") @db.Uuid
  marketName                String?                @map("market_name") @db.Text
  investmentSummary         String?                @map("investment_summary") @db.Text
  businessPlanSummary       String?                @map("business_plan_summary") @db.Text
  legacySku                 sku_type?              @map("legacy_sku")
  legacyStatus              deal_status?           @map("legacy_status")
  targetCloseDate           DateTime?              @map("target_close_date") @db.Date
  notes                     String?                @db.Text
  createdBy                 String                 @map("created_by") @db.Uuid
  createdAt                 DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  source                    String?                @db.Text
  financialModelAssumptions Json?                  @map("financial_model_assumptions") @db.JsonB
  financialModelScenarios   Json?                  @map("financial_model_scenarios") @db.JsonB
  waterfallStructures       Json?                  @map("waterfall_structures") @db.JsonB
  debtComparisons           Json?                  @map("debt_comparisons") @db.JsonB

  org          Org          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  jurisdiction Jurisdiction @relation(fields: [jurisdictionId], references: [id], onDelete: Restrict)
  creator      User         @relation("deal_created_by", fields: [createdBy], references: [id], onDelete: Restrict)
  primaryAsset Asset?       @relation("deal_primary_asset", fields: [primaryAssetId, orgId], references: [id, orgId], onDelete: Restrict)

  parcels                        Parcel[]
  dealAssets                     DealAsset[]
  tasks                          Task[]
  outreach                       Outreach[]
  runs                           Run[]
  artifacts                      Artifact[]
  uploads                        Upload[]
  documentExtractions            DocumentExtraction[]
  conversations                  Conversation[]
  entityDeals                    EntityDeal[]
  taxEvents                      TaxEvent[]
  notifications                  Notification[]
  approvalRequests               ApprovalRequest[]
  outcome                        DealOutcome?
  terms                          DealTerms?
  entitlementPath                EntitlementPath?
  propertyTitle                  PropertyTitle?
  propertySurvey                 PropertySurvey?
  environmentalAssessments       EnvironmentalAssessment[]
  tenants                        Tenant[]
  tenantLeases                   TenantLease[]
  developmentBudget              DevelopmentBudget?
  capitalSources                 CapitalSource[]
  capitalDeployments             CapitalDeployment[]
  equityWaterfalls               EquityWaterfall[]
  financings                     DealFinancing[]
  risks                          DealRisk[]
  stakeholders                   DealStakeholder[]
  mapWorkspaces                  MapWorkspace[]
  assumptionActuals              AssumptionActual[]
  entitlementGraphNodes          EntitlementGraphNode[]
  entitlementOutcomePrecedents   EntitlementOutcomePrecedent[]
  entitlementPredictionSnapshots EntitlementPredictionSnapshot[]
  counterfactualLogs             CounterfactualDealLog[]
  stageHistory                   DealStageHistory[]
  generalizedScorecards          GeneralizedScorecard[]
  moduleStates                   ModuleState[]
  comments                       DealComment[]
  contingencies                  DealContingency[]
  assetPerformancePeriods        AssetPerformancePeriod[]
  capExItems                     CapExItem[]
  tenantChangeEvents             TenantChangeEvent[]

  @@unique([id, orgId])
  @@index([orgId])
  @@index([jurisdictionId])
  @@index([status])
  @@index([orgId, primaryAssetId])
  @@map("deals")
}

model Asset {
  id                String            @id @default(uuid()) @db.Uuid
  orgId             String            @map("org_id") @db.Uuid
  name              String            @db.Text
  address           String?           @db.Text
  city              String?           @db.Text
  state             String?           @db.Text
  zip               String?           @db.Text
  county            String?           @db.Text
  parcelNumber      String?           @map("parcel_number") @db.Text
  assetClass        deal_asset_class? @map("asset_class")
  assetSubtype      String?           @map("asset_subtype") @db.Text
  lat               Decimal?          @db.Decimal(10, 7)
  lng               Decimal?          @db.Decimal(10, 7)
  acreage           Decimal?          @db.Decimal(12, 4)
  sfGross           Decimal?          @map("sf_gross") @db.Decimal(14, 2)
  sfNet             Decimal?          @map("sf_net") @db.Decimal(14, 2)
  yearBuilt         Int?              @map("year_built")
  zoning            String?           @db.Text
  zoningDescription String?           @map("zoning_description") @db.Text
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  org             Org         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  primaryForDeals Deal[]      @relation("deal_primary_asset")
  dealAssets      DealAsset[]

  @@unique([id, orgId])
  @@index([orgId])
  @@index([orgId, parcelNumber])
  @@index([orgId, address])
  @@map("assets")
}

model DealAsset {
  id        String          @id @default(uuid()) @db.Uuid
  orgId     String          @map("org_id") @db.Uuid
  dealId    String          @map("deal_id") @db.Uuid
  assetId   String          @map("asset_id") @db.Uuid
  role      deal_asset_role
  createdAt DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  org   Org   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  deal  Deal  @relation(fields: [dealId, orgId], references: [id, orgId], onDelete: Cascade)
  asset Asset @relation(fields: [assetId, orgId], references: [id, orgId], onDelete: Cascade)

  @@unique([dealId, assetId])
  @@index([orgId])
  @@index([orgId, dealId])
  @@index([orgId, assetId])
  @@map("deal_assets")
}

model WorkflowTemplate {
  id          String                @id @default(uuid()) @db.Uuid
  orgId       String                @map("org_id") @db.Uuid
  key         workflow_template_key
  name        String                @db.Text
  description String?               @db.Text
  isDefault   Boolean               @default(false) @map("is_default")
  createdAt   DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)

  org    Org             @relation(fields: [orgId], references: [id], onDelete: Cascade)
  stages WorkflowStage[]

  @@unique([id, orgId])
  @@unique([orgId, key])
  @@index([orgId])
  @@map("workflow_templates")
}

model WorkflowStage {
  id           String         @id @default(uuid()) @db.Uuid
  orgId        String         @map("org_id") @db.Uuid
  templateId   String         @map("template_id") @db.Uuid
  key          deal_stage_key
  name         String         @db.Text
  ordinal      Int
  description  String?        @db.Text
  requiredGate String?        @map("required_gate") @db.Text
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  org      Org              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  template WorkflowTemplate @relation(fields: [templateId, orgId], references: [id, orgId], onDelete: Cascade)

  @@unique([templateId, key])
  @@unique([templateId, ordinal])
  @@index([orgId])
  @@index([orgId, templateId])
  @@map("workflow_stages")
}

model DealStageHistory {
  id                String          @id @default(uuid()) @db.Uuid
  dealId            String          @map("deal_id") @db.Uuid
  orgId             String          @map("org_id") @db.Uuid
  fromStageKey      deal_stage_key? @map("from_stage_key")
  toStageKey        deal_stage_key  @map("to_stage_key")
  changedBy         String?         @map("changed_by") @db.Uuid
  changedAt         DateTime        @default(now()) @map("changed_at") @db.Timestamptz(6)
  note              String?         @db.Text
  decisionCriteria  Json?           @map("decision_criteria") @db.JsonB
  decisionMetrics   Json?           @map("decision_metrics") @db.JsonB
  decisionRationale String?         @map("decision_rationale") @db.Text
  approvalRequestId String?         @map("approval_request_id") @db.Uuid

  deal Deal @relation(fields: [dealId, orgId], references: [id, orgId], onDelete: Cascade)
  org  Org  @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([orgId, dealId])
  @@index([toStageKey])
  @@map("deal_stage_history")
}

model DealComment {
  id              String    @id @default(uuid()) @db.Uuid
  orgId           String    @map("org_id") @db.Uuid
  dealId          String    @map("deal_id") @db.Uuid
  authorUserId    String    @map("author_user_id") @db.Uuid
  parentCommentId String?   @map("parent_comment_id") @db.Uuid
  body            String    @db.Text
  mentions        String[]  @default([]) @map("mentions") @db.Uuid
  pinned          Boolean   @default(false)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)

  org    Org          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  deal   Deal         @relation(fields: [dealId, orgId], references: [id, orgId], onDelete: Cascade)
  author User         @relation("deal_comment_author", fields: [authorUserId], references: [id], onDelete: Restrict)
  parent DealComment? @relation("DealCommentThread", fields: [parentCommentId], references: [id], onDelete: SetNull)
  replies DealComment[] @relation("DealCommentThread")

  @@index([orgId, dealId, createdAt])
  @@index([parentCommentId])
  @@map("deal_comments")
}

model DealContingency {
  id                          String    @id @default(uuid()) @db.Uuid
  orgId                       String    @map("org_id") @db.Uuid
  dealId                      String    @map("deal_id") @db.Uuid
  category                    String    @db.Text // title|survey|environmental|appraisal|financing|inspection|hoa|zoning|utilities|other
  title                       String    @db.Text
  description                 String?   @db.Text
  status                      String    @default("open") @db.Text // open|in_progress|satisfied|waived|failed
  deadline                    DateTime? @db.Timestamptz(6)
  ownerUserId                 String?   @map("owner_user_id") @db.Uuid
  satisfiedAt                 DateTime? @map("satisfied_at") @db.Timestamptz(6)
  satisfiedBy                 String?   @map("satisfied_by") @db.Uuid
  satisfactionNotes           String?   @map("satisfaction_notes") @db.Text
  noticeDaysBeforeDeadline    Int       @default(7) @map("notice_days_before_deadline")
  createdAt                   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  org   Org  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  deal  Deal @relation(fields: [dealId, orgId], references: [id, orgId], onDelete: Cascade)
  owner User? @relation("deal_contingency_owner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  @@index([orgId, dealId, status])
  @@index([orgId, deadline])
  @@map("deal_contingencies")
}

model PortfolioAlert {
  id             String    @id @default(uuid()) @db.Uuid
  orgId          String    @map("org_id") @db.Uuid
  dealId         String?   @map("deal_id") @db.Uuid
  category       String    @db.Text
  severity       String    @db.Text
  title          String    @db.Text
  summary        String    @db.Text
  detail         Json      @default("{}") @db.JsonB
  fingerprint    String    @db.Text
  firstSeenAt    DateTime  @default(now()) @map("first_seen_at") @db.Timestamptz(6)
  lastSeenAt     DateTime  @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  acknowledgedAt DateTime? @map("acknowledged_at") @db.Timestamptz(6)
  acknowledgedBy String?   @map("acknowledged_by") @db.Uuid
  snoozedUntil   DateTime? @map("snoozed_until") @db.Timestamptz(6)
  resolvedAt     DateTime? @map("resolved_at") @db.Timestamptz(6)

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, fingerprint])
  @@index([orgId, firstSeenAt(sort: Desc)])
  @@index([orgId, dealId])
  @@map("portfolio_alerts")
}

model OrgInvestmentCriteria {
  id                    String   @id @default(uuid()) @db.Uuid
  orgId                 String   @unique @map("org_id") @db.Uuid
  minIrrPct             Decimal? @map("min_irr_pct") @db.Decimal(5, 2)
  maxLtvPct             Decimal? @map("max_ltv_pct") @db.Decimal(5, 2)
  minDscr               Decimal? @map("min_dscr") @db.Decimal(5, 2)
  preferredAssetClasses String[] @default([]) @map("preferred_asset_classes")

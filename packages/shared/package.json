{
  "name": "@entitlement-os/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./evidence": {
      "types": "./dist/evidence.d.ts",
      "default": "./dist/evidence.js"
    },
    "./crypto": {
      "types": "./dist/crypto/index.d.ts",
      "default": "./dist/crypto/index.js"
    },
    "./financial-assumptions": {
      "types": "./dist/financial-assumptions.d.ts",
      "default": "./dist/financial-assumptions.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "default": "./dist/errors.js"
    },
    "./extraction-schemas": {
      "types": "./dist/extraction-schemas.d.ts",
      "default": "./dist/extraction-schemas.js"
    },
    "./intent-classification": {
      "types": "./dist/intent-classification.d.ts",
      "default": "./dist/intent-classification.js"
    },
    "./memory-write": {
      "types": "./dist/memory-write.d.ts",
      "default": "./dist/memory-write.js"
    },
    "./opportunity-phase3": {
      "types": "./dist/opportunity-phase3.d.ts",
      "default": "./dist/opportunity-phase3.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "lint": "eslint src --max-warnings=0 --no-error-on-unmatched-pattern",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "eslint": "^9.20.1",
    "typescript": "^5.7.3",
    "vitest": "^4.1.0"
  }
}

{
  "name": "@entitlement-os/evidence",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\" --ignore-pattern \"src/__tests__/**\" --max-warnings=0 --no-error-on-unmatched-pattern",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@entitlement-os/db": "workspace:*",
    "@entitlement-os/openai": "workspace:*",
    "@entitlement-os/shared": "workspace:*",
    "@prisma/client": "~6.19.2",
    "html-to-text": "^9.0.5",
    "mammoth": "^1.12.0",
    "playwright": "^1.50.0",
    "unpdf": "^1.4.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "eslint": "^9.20.1",
    "typescript": "^5.7.3",
    "vitest": "^4.1.0"
  }
}

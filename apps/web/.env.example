# PC server / tunnel reference: docs/server-manifest.json (also docs/SERVER_MANAGEMENT.md, docs/CLOUDFLARE.md)
#
# ============================================
# Database Configuration
# ============================================
# Local PostgreSQL (Docker Compose on port 54323)
DATABASE_URL=postgresql://postgres:postgres@localhost:54323/entitlement_os?schema=public
DIRECT_DATABASE_URL=postgresql://postgres:postgres@localhost:54323/entitlement_os?schema=public
# Local API Server (FastAPI via Cloudflare Tunnel)
# Tile proxy and property database queries route through this API
# Generate API key with: openssl rand -hex 32
LOCAL_API_URL=https://api.gallagherpropco.com
LOCAL_API_KEY=your-secret-api-key-here
CF_ACCESS_CLIENT_ID=abec4c234d074aa8271cdc65cf0be520.access
CF_ACCESS_CLIENT_SECRET=94d16bd611e1bb3a2e0714113d06a31b0a81fdc872c3d2c3254882b9ce35b6df
# Required for evidence uploads (parish-pack, change-detection, source-ingestion, worker)
GATEWAY_SERVICE_USER_ID=uuid-of-valid-user-in-your-org

# Cron Job Authentication
# Used by Vercel Cron for change detection and parish pack refresh
# Generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here

READ_REPLICA_DATABASE_URL=
ENABLE_READ_REPLICA=false
PRISMA_CONNECTION_LIMIT=15
PRISMA_POOL_TIMEOUT_SECONDS=20
# Required for screening, copilot, and deal-room integrations.
# In local development, you can use http://localhost:8000.
# In production/staging, you must set this to your deployed backend API origin.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# ============================================
# NextAuth / Auth.js (Required for production)
# ============================================
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Canonical site URL (e.g. https://gallagherpropco.com). Optional; Auth.js infers from Host when trustHost is true.
AUTH_URL=https://gallagherpropco.com

# ============================================
# Google OAuth (Primary sign-in method)
# ============================================
# Create at https://console.cloud.google.com/apis/credentials
# Redirect URIs: https://gallagherpropco.com/api/auth/callback/google, http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ============================================
# Auth Allowlist (Optional)
# ============================================
# Comma-separated list of approved login emails.
ALLOWED_LOGIN_EMAILS=blake@gallagherpropco.com
# Optional client-side override (baked at build time if set)
NEXT_PUBLIC_ALLOWED_LOGIN_EMAILS=blake@gallagherpropco.com
# Emergency-only break-glass path for credentials auth fallback.
# Keep disabled by default; enable only for short incident recovery windows.
AUTH_ENABLE_CREDENTIALS_FALLBACK=false
# Used only when AUTH_ENABLE_CREDENTIALS_FALLBACK=true and DB password_hash fails.
AUTH_CREDENTIALS_FALLBACK_PASSWORD=

# ============================================
# OpenAI Configuration
# ============================================
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key

# ============================================
# Codex Admin UI
# ============================================
# WebSocket endpoint for the Codex App Server (for local app-server dev)
CODEX_APP_SERVER_URL=ws://127.0.0.1:8765
# Relay endpoint for /admin/codex client connections.
# Use /api/admin/codex for local dev and
# wss://agents.gallagherpropco.com/codex for production.
# NEXT_PUBLIC_CODEX_RELAY_URL=/api/admin/codex

# Optional chat session memory tuning
AGENT_SESSION_COMPACTION_TOKEN_THRESHOLD=6000
AGENT_SESSION_COMPACTION_KEEP_RECENT_MESSAGES=24
AGENT_SESSION_DEDUPE_LOOKBACK=200

# ============================================
# Optional: Perplexity API (for research agent)
# ============================================
# Get from https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your-perplexity-key

# ============================================
# Optional: Sentry Error Tracking
# ============================================
# Get from https://sentry.io/settings/projects/
SENTRY_AUTH_TOKEN=
SENTRY_ORG=gpc-ul
SENTRY_PROJECT=entitlement-os-web
SENTRY_DSN=your-sentry-dsn
NEXT_PUBLIC_SENTRY_DSN=your-public-sentry-dsn
SENTRY_AGENTS_DSN=your-agents-sentry-dsn
SENTRY_TRACES_BASE_SAMPLE_RATE=0.01
SENTRY_TRACES_CHAT_SAMPLE_RATE=0.2
SENTRY_AGENTS_TRACES_SAMPLE_RATE=0.2

# ============================================
# Market Trajectory Agent (Socrata + Google Places)
# ============================================
# Socrata municipal open-data portal (building permits)
SOCRATA_BASE_URL=https://data.brla.gov/resource
SOCRATA_EBR_PERMITS_DATASET_ID=7fq7-8j7r
SOCRATA_APP_TOKEN=
# Google Places API (gentrification indicators). Required for Places tool.
GOOGLE_MAPS_API_KEY=
# Google Maps Grounding Lite MCP (agents get search_places, compute_routes, lookup_weather)
GOOGLE_MAPS_GROUNDING_LITE_ENABLED=false

# ============================================
# Optional: Backblaze B2 (for file storage)
# ============================================
B2_APPLICATION_KEY_ID=your-key-id
B2_APPLICATION_KEY=your-key
B2_BUCKET_NAME=gpc-dashboard-files
